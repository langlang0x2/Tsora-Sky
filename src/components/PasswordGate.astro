---
const SONG_PASSWORD = 'tsora2026'
---

<div id="password-gate" class="flex flex-col items-center justify-center py-20">
  <p class="mb-4 text-sm text-muted-foreground">此页面需要密码访问</p>
  <input
    id="password-input"
    type="password"
    placeholder="请输入密码"
    class="rounded border px-3 py-2 text-sm"
  />
  <p id="password-error" class="mt-2 hidden text-sm text-red-500"></p>
</div>

<div id="password-content" class="hidden">
  <slot />
</div>

<script>
  const PASSWORD = 'tsora2026'
  const gate = document.getElementById('password-gate')!
  const content = document.getElementById('password-content')!
  const input = document.getElementById('password-input') as HTMLInputElement
  const error = document.getElementById('password-error')!

  if (sessionStorage.getItem('songs-auth') === PASSWORD) {
    gate.classList.add('hidden')
    content.classList.remove('hidden')
  }

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      if (input.value === PASSWORD) {
        sessionStorage.setItem('songs-auth', PASSWORD)
        gate.classList.add('hidden')
        content.classList.remove('hidden')
        error.classList.add('hidden')
      } else {
        error.textContent = '密码错误'
        error.classList.remove('hidden')
        input.value = ''
      }
    }
  })
</script>
